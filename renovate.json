{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "America/New_York",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "prConcurrentLimit": 5,
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Group and automerge GitHub Actions minor/patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions",
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group all non-major dev dependency patches/minors into one weekly PR",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "excludePackagePatterns": ["^cloudflare", "^@cloudflare", "^react", "^react-dom", "^vite", "^@vitejs"],
      "groupName": "dev dependency updates",
      "schedule": ["before 6am on Monday"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Automerge security patches immediately regardless of scope",
      "matchCategories": ["security"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Group Cloudflare packages — review manually",
      "matchPackagePatterns": ["^cloudflare", "^@cloudflare", "^wrangler"],
      "groupName": "Cloudflare",
      "automerge": false
    },
    {
      "description": "Group React packages — review manually",
      "matchPackageNames": ["react", "react-dom", "@types/react", "@types/react-dom"],
      "groupName": "React",
      "automerge": false
    },
    {
      "description": "Group Vite/Vitest packages — review manually",
      "matchPackagePatterns": ["^vite", "^@vitejs", "^vitest", "^@vitest"],
      "groupName": "Vite & Vitest",
      "automerge": false
    },
    {
      "description": "Group typescript-eslint — review manually alongside lint changes",
      "matchPackagePatterns": ["^typescript-eslint", "^@typescript-eslint"],
      "groupName": "typescript-eslint",
      "automerge": false
    },
    {
      "description": "Group Playwright packages — review manually",
      "matchPackagePatterns": ["^playwright", "^@playwright"],
      "groupName": "Playwright",
      "automerge": false
    },
    {
      "description": "Group Tailwind packages — review manually",
      "matchPackagePatterns": ["^tailwindcss", "^@tailwindcss"],
      "groupName": "Tailwind CSS",
      "automerge": false
    },
    {
      "description": "Never automerge major version bumps; require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    }
  ]
}
